pipeline {
  agent {
    kubernetes {
      defaultContainer 'python'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    pipelinebench.io/workload: sample-app
spec:
  serviceAccountName: pipelinebench-jenkins
  restartPolicy: Never
  containers:
    - name: python
      image: python:3.12-slim
      command:
        - cat
      tty: true
"""
    }
  }

  parameters {
    string(name: 'RUN_ID', defaultValue: '0', description: 'PipelineBench run id')
  }

  environment {
    SAMPLE_APP_DIR = '/workspace/workloads/sample-app'
    PIPELINEBENCH_REPO_ARCHIVE_URL = 'http://gitea-http.pipelinebench-gitea.svc.cluster.local:3000/filip/sample-app/archive/main.zip'
  }

  stages {
    stage('Checkout') {
      steps {
        echo "Fetching PipelineBench workload from local Gitea. RUN_ID=${params.RUN_ID}"
        sh '''
          python3 - <<'PY_FETCH'
import io
import os
import shutil
import urllib.request
import zipfile

target = os.environ["SAMPLE_APP_DIR"]
shutil.rmtree(target, ignore_errors=True)
os.makedirs(target, exist_ok=True)
with urllib.request.urlopen(os.environ["PIPELINEBENCH_REPO_ARCHIVE_URL"], timeout=30) as response:
    payload = response.read()
with zipfile.ZipFile(io.BytesIO(payload)) as archive:
    prefix = archive.namelist()[0].split("/")[0] + "/"
    for member in archive.infolist():
        if member.is_dir():
            continue
        rel = member.filename[len(prefix):]
        if not rel:
            continue
        destination = os.path.join(target, rel)
        os.makedirs(os.path.dirname(destination), exist_ok=True)
        with archive.open(member) as source, open(destination, "wb") as output:
            shutil.copyfileobj(source, output)
PY_FETCH
          find "$SAMPLE_APP_DIR" -maxdepth 3 -type f | sort
        '''
      }
    }

    stage('Install Dependencies') {
      steps {
        sh 'python3 -m pip install --user -r ${SAMPLE_APP_DIR}/requirements.txt'
      }
    }

    stage('Unit Tests') {
      steps {
        sh 'PYTHONPATH=${SAMPLE_APP_DIR} python3 -m unittest discover -s ${SAMPLE_APP_DIR}/tests'
      }
    }

    stage('CPU Benchmark') {
      steps {
        sh 'python3 ${SAMPLE_APP_DIR}/benchmark/cpu_task.py'
      }
    }

    stage('Memory Benchmark') {
      steps {
        sh 'python3 ${SAMPLE_APP_DIR}/benchmark/memory_task.py'
      }
    }

    stage('Docker Build') {
      steps {
        sh '''
          if command -v docker >/dev/null 2>&1; then
            docker build -t pipelinebench/sample-app:jenkins-${RUN_ID} ${SAMPLE_APP_DIR}
          else
            echo "Docker CLI is not available in this Jenkins agent; skipping image build."
          fi
        '''
      }
    }
  }

  post {
    always {
      echo "PipelineBench Jenkins run ${params.RUN_ID} finished with ${currentBuild.currentResult}"
    }
  }
}
